# =============================================================
# Frontend Environment Variables (Vite)
# =============================================================
# Copy this to .env and fill in your values.
# Vite injects these at BUILD time (prefixed with VITE_).
# =============================================================

# Nakama server hostname (no protocol, no port)
VITE_NAKAMA_HOST=localhost

# Nakama HTTP/WebSocket API port
VITE_NAKAMA_PORT=7350

# Nakama server key (must match backend local.yml socket.server_key)
VITE_NAKAMA_KEY=tictactoe_server_key

# Enable SSL/TLS (set to "true" for production with HTTPS)
VITE_NAKAMA_SSL=false
