# =============================================================
# Tic Tac Toe — Root Environment Variables
# =============================================================
# Copy this to .env and fill in your production values.
# Used by docker-compose.yaml for the backend services.
# =============================================================

# ---- PostgreSQL ----
POSTGRES_DB=nakama
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# ---- Nakama ----
NAKAMA_SERVER_KEY=CHANGE_ME_TO_A_RANDOM_SECRET
NAKAMA_CONSOLE_USERNAME=admin
NAKAMA_CONSOLE_PASSWORD=CHANGE_ME_CONSOLE_PASSWORD
